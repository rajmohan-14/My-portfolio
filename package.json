{
  "name": "team-member",
  "version": "0.0.1",
  "description": "React Advanced Image Components",
  "files": [
    "./lib/"
  ],
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "types": "./lib/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/esm/index.d.ts",
        "default": "./lib/esm/index.js"
      },
      "require": {
        "default": "./lib/cjs/index.js"
      }
    },
    "./css": {
      "default": "./lib/cjs/index.min.css"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:lib": "rimraf ./lib/  && yarn build:lib:dev",
    "build:lib:dev": "yarn prettier && yarn watch:lib && yarn build:lib:esm && yarn build:lib:cjs && yarn build:css",
    "build:css": "css-minify -f ./app/src/index.css -o ./lib/cjs",
    "watch": "npx tailwindcss -i ./app/src/input.css -o ./app/src/index.css",
    "watch:lib": "npx tailwindcss -c ./app/src/tailwind.config.ts -i ./app/src/input.css -o ./app/src/index.css",
    "prettier": "npx prettier --write .",
    "build:lib:cjs": "tsc -p tsconfig.lib.json",
    "build:lib:esm": "tsc -p tsconfig.lib.json --module esnext --declaration --outDir ./lib/esm",
    "lint": "eslint app --ext ts,tsx,js,jsx,cjs --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint app --ext js,jsx,ts,tsx,cjs --fix",
    "format": "prettier --write 'app/**/*.{js,jsx,ts,tsx,css,html}'",
    "postbuild": "next-sitemap --config next-sitemap.config.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NafisMahmudAyon/team-member.git"
  },
  "keywords": [
    "ui",
    "landing page",
    "Landing Page",
    "Landing Page UI",
    "landing page UI",
    "UI"
  ],
  "author": "Nafis Mahmud Ayon <nafismahmudayon@gmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/NafisMahmudAyon/team-member/issues"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@supabase/supabase-js": "^2.45.2",
    "@tsparticles/react": "^4.0.2",
    "@tsparticles/slim": "^4.0.2",
    "@types/dompurify": "^3.0.5",
    "blog-x-ui": "^0.0.8",
    "clsx": "^2.1.1",
    "dompurify": "^3.1.6",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^11.18.2",
    "fs-extra": "^11.3.5",
    "lucide-react": "^0.537.0",
    "next": "^15.1.7",
    "next-sitemap": "^4.2.3",
    "nexus-accordion": "^0.0.6",
    "nprogress": "^0.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-focus-lock": "^2.13.6",
    "react-markdown": "^9.0.1",
    "react-remove-scroll": "^2.7.1",
    "react-syntax-highlighter": "^15.6.1",
    "react-toastify": "^10.0.5",
    "rehype-highlight": "^7.0.1",
    "rehype-prism": "^2.3.3",
    "rehype-prism-plus": "^2.0.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^3.3.1",
    "typofx": "^0.0.2"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "css-minify": "^2.0.0",
    "eslint": "^8",
    "eslint-config-next": "^15.1.7",
    "postcss": "^8",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
